# --- Database (Neon Postgres) ---
# Create a free project at https://neon.tech and paste the pooled connection string.
DATABASE_URL="postgresql://user:pass@ep-xxxx-pooler.region.aws.neon.tech/milsim?sslmode=require"
# Optional: direct (non-pooled) URL used by `prisma migrate` and `prisma db push`.
DIRECT_URL="postgresql://user:pass@ep-xxxx.region.aws.neon.tech/milsim?sslmode=require"

# --- Auth.js ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET="replace-me"
# In production, set to your deployed URL (e.g. https://milsim-hub.vercel.app)
NEXTAUTH_URL="http://localhost:3000"

# --- Discord application ---
# https://discord.com/developers/applications -> New Application -> OAuth2
# Add redirect: http://localhost:3000/api/auth/callback/discord
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# --- Discord bot (used by guild role checks + cron sync) ---
# Same application -> Bot -> Reset Token. Invite the bot to your guild with
# scope=bot and the "Read Members" + "View Channels" permissions.
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
# Role ID required for site access. Right-click the role in Discord (with Dev Mode on) -> Copy ID.
AUTHORIZED_ROLE_ID=""

# --- UploadThing ---
# https://uploadthing.com -> create app -> API Keys
UPLOADTHING_TOKEN=""

# --- Discord channel webhooks (optional) ---
# Server Settings -> Integrations -> Webhooks -> New Webhook -> Copy URL.
# Default fallback: bulletins, AAR, and (if SCHEDULE not set) new events all post here.
DISCORD_BULLETIN_WEBHOOK_URL=""
# Dedicated channel for new ops + AAR drops. Falls back to BULLETIN if empty.
DISCORD_SCHEDULE_WEBHOOK_URL=""

# --- Vercel Cron secret (any random string) ---
CRON_SECRET="replace-me"
